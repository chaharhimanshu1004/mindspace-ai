DATABASE_URL="postgresql://user:pass@host:5432/mindspace?schema=public"
DIRECT_URL="postgresql://user:pass@host:5432/mindspace?schema=public"

PORT=4000
NODE_ENV=development

JWT_SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN="30d"

CORS_ORIGIN="http://localhost:3000"

BCRYPT_ROUNDS=12

REDIS_URL="redis://localhost:6379"

AI_ENGINE_URL="http://localhost:5000"
AI_ENGINE_TOKEN="replace-with-shared-secret"

GEMINI_API_KEY="replace-me"
GEMINI_CHAT_MODEL="gemini-2.5-flash"

CHAT_TOP_K=8

GOOGLE_CLIENT_ID="google_client_id"
GOOGLE_CLIENT_SECRET="google_client_secret"
GOOGLE_REDIRECT_URI="https://your_website_url"

CREDENTIALS_SECRET="generate-with: openssl rand -hex 32"
