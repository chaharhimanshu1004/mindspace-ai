APP_ENV=development
PORT=5001

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/mindspace
DIRECT_URL=postgresql+asyncpg://user:pass@host:5432/mindspace

REDIS_URL=redis://localhost:6379

LLM_PROVIDER=gemini
GEMINI_API_KEY=replace-me
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

EMBED_DIM=768

STREAM_BLOCK_MS=5000
STREAM_BATCH_SIZE=1
MAX_DELIVERIES=5
STAGE_TIMEOUT_SECONDS=90

ENTITY_DEDUP_COSINE=0.85

INTERNAL_API_TOKEN=replace-with-shared-secret
SEARCH_TOP_K=8
